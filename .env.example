# ===== WHATSAPP / 11ZA / ELEVENZA =====
# Webhook Authentication
# Webhooks are verified using x-api-key header
# Header value must match ELEVENZA_WEBHOOK_SECRET
WHATSAPP_API_URL=https://internal.11za.in/apis
WHATSAPP_API_TOKEN=your_api_token_here
ELEVENZA_WEBHOOK_SECRET=your_webhook_secret_here
ORIGIN_WEBSITE=https://yourwebsite.com

# ===== DATABASE =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lifeos?retryWrites=true&w=majority
DB_NAME=lifeos

# ===== AI ENGINE =====
GROQ_API_KEY=your_groq_api_key

# ===== SERVER =====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===== LOGGING =====
LOG_LEVEL=info

# ===== TIMEZONE =====
DEFAULT_TIMEZONE=Asia/Kolkata
