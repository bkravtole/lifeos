# ===== WHATSAPP / 11ZA =====
# 11za API Integration
# Endpoints: 
#   Text: /sendMessage/sendMessages
#   Interactive: /sendMessage/sendInteractiveMessage
WHATSAPP_API_URL=https://api.11za.in
WHATSAPP_API_TOKEN=your_11za_auth_token
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verification_token
ORIGIN_WEBSITE=https://yourwebsite.com

# ===== DATABASE =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lifeos?retryWrites=true&w=majority
DB_NAME=lifeos

# ===== AI ENGINE =====
GROQ_API_KEY=your_groq_api_key

# ===== SERVER =====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===== LOGGING =====
LOG_LEVEL=info

# ===== TIMEZONE =====
DEFAULT_TIMEZONE=Asia/Kolkata
